/**app.wxss - 大熊动医华南医学检验实验室 Theme**/
/**Design: Clinical Precision meets Warm Professionalism**/

page {
  font-family: 'PingFang SC', 'SF Pro Display', -apple-system, sans-serif;
  font-size: 28rpx;
  color: #1A2B3C;
  background: #F7F9FB;
}

/* ============ 色彩系统 ============ */
page {
  /* 主色系 - 深青蓝 */
  --color-primary: #0A6E7C;
  --color-primary-light: #14919B;
  --color-primary-dark: #085561;

  /* 强调色 - 琥珀金 */
  --color-accent: #D4A853;
  --color-accent-light: #E8C478;

  /* 背景色 */
  --bg-page: #F7F9FB;
  --bg-card: #FFFFFF;
  --bg-section: #EEF2F5;
  --bg-hover: #F0F4F7;

  /* 文字色 */
  --text-primary: #1A2B3C;
  --text-secondary: #5A6B7C;
  --text-tertiary: #8A9BAC;
  --text-inverse: #FFFFFF;

  /* 状态色 */
  --color-success: #34A853;
  --color-warning: #F5A623;
  --color-error: #DC3545;
  --color-info: #0A6E7C;

  /* 价格色 */
  --color-price: #D4A853;
  --color-price-light: #E8C478;

  /* 边框与分割 */
  --border-color: #E2E8F0;
  --divider-color: #F0F4F7;

  /* 阴影 - 简洁内敛 */
  --shadow-xs: 0 1rpx 3rpx rgba(10, 110, 124, 0.04);
  --shadow-sm: 0 2rpx 8rpx rgba(10, 110, 124, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(10, 110, 124, 0.08);
  --shadow-lg: 0 8rpx 24rpx rgba(10, 110, 124, 0.10);
  --shadow-xl: 0 12rpx 32rpx rgba(10, 110, 124, 0.12);

  /* 圆角 - 几何感 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-full: 9999rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;
  --space-2xl: 48rpx;
}

/* ============ 全局页面容器 ============ */
.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ============ 通用组件 ============ */

/* 通用卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.card-soft {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xs);
  border: 1rpx solid var(--border-color);
}

/* 渐变背景 */
.gradient-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
}

.gradient-accent {
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-light) 100%);
}

/* 通用按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s ease;
}

.btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-primary {
  background: var(--color-primary);
  color: var(--text-inverse);
  box-shadow: var(--shadow-sm);
}

.btn-primary:active {
  background: var(--color-primary-dark);
  box-shadow: var(--shadow-md);
}

.btn-accent {
  background: var(--color-accent);
  color: var(--text-primary);
  box-shadow: var(--shadow-sm);
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
}

.btn-ghost {
  background: var(--bg-section);
  color: var(--text-primary);
}

/* 通用输入框 */
.input {
  background: var(--bg-section);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  transition: all 0.2s ease;
}

.input:focus {
  border-color: var(--color-primary);
  background: var(--bg-card);
  box-shadow: 0 0 0 4rpx rgba(10, 110, 124, 0.08);
}

.input::placeholder {
  color: var(--text-tertiary);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(10, 110, 124, 0.10);
  color: var(--color-primary);
}

.tag-accent {
  background: rgba(212, 168, 83, 0.12);
  color: #B8923E;
}

.tag-success {
  background: rgba(52, 168, 83, 0.10);
  color: var(--color-success);
}

.tag-warning {
  background: rgba(245, 166, 35, 0.12);
  color: #D4890D;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-tertiary);
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
  /* 使用线性图标替代emoji */
}

.empty-state .icon::before {
  content: '📋';
  font-family: initial;
}

.empty-state .text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.empty-state .hint {
  font-size: 26rpx;
  margin-top: 8rpx;
  opacity: 0.7;
}

/* ============ 动画 ============ */

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-16rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(16rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* 动画类 - 克制、专业 */
.anim-fade-in { animation: fadeIn 0.3s ease forwards; }
.anim-fade-in-up { animation: fadeInUp 0.35s ease forwards; }
.anim-fade-in-down { animation: fadeInDown 0.3s ease forwards; }
.anim-slide-in-left { animation: slideInLeft 0.3s ease forwards; }
.anim-slide-in-right { animation: slideInRight 0.3s ease forwards; }
.anim-scale-in { animation: scaleIn 0.3s ease forwards; }

/* 交错动画延迟 - 更克制的延迟 */
.delay-1 { animation-delay: 0.05s; }
.delay-2 { animation-delay: 0.1s; }
.delay-3 { animation-delay: 0.15s; }
.delay-4 { animation-delay: 0.2s; }
.delay-5 { animation-delay: 0.25s; }
.delay-6 { animation-delay: 0.3s; }

/* ============ 分割线 ============ */

.divider {
  height: 1rpx;
  background: var(--divider-color);
}

.divider-soft {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--border-color), transparent);
}

/* ============ 工具类 ============ */

/* 文字省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Flex */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.gap-sm { gap: var(--space-sm); }
.gap-md { gap: var(--space-md); }
.gap-lg { gap: var(--space-lg); }
