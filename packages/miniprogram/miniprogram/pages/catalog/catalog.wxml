<view class="page">
  <view class="layout">
    <!-- 左侧分类 -->
    <scroll-view class="sidebar" scroll-y>
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="sidebar-item {{activeCategory === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onCategoryTap"
      >{{item.name}}</view>
    </scroll-view>
    <!-- 右侧商品 -->
    <scroll-view class="content" scroll-y>
      <view
        wx:for="{{products}}"
        wx:key="id"
        class="product-item"
        data-id="{{item.id}}"
        bindtap="onProductTap"
      >
        <text class="name">{{item.name}}</text>
        <text class="price">¥{{item.personalPrice || item.institutionPrice}}</text>
      </view>
      <view wx:if="{{products.length === 0}}" class="empty">暂无商品</view>
    </scroll-view>
  </view>
</view>
