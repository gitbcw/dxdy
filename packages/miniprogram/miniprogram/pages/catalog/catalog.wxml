<view class="page">
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索商品名称..."
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearchConfirm"
    />
    <view wx:if="{{searchKeyword}}" class="search-clear" catchtap="onSearchClear">×</view>
  </view>

  <scroll-view scroll-x class="quick-filters">
    <view
      wx:for="{{quickFilters}}"
      wx:key="key"
      class="filter-pill {{activeQuickFilter === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onQuickFilterTap"
    >
      {{item.label}} {{item.count}}
    </view>
  </scroll-view>

  <view class="layout">
    <scroll-view class="sidebar" scroll-y>
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="sidebar-item {{activeCategory === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onCategoryTap"
      >
        <text class="sidebar-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view class="content" scroll-y>
      <view
        wx:for="{{products}}"
        wx:key="id"
        class="product-item {{item.lowStock ? 'warn' : ''}}"
        data-id="{{item.id}}"
        bindtap="onProductTap"
      >
        <view class="product-top">
          <text class="tag">{{item.tagText}}</text>
          <text class="stock {{item.lowStock ? 'warn' : ''}}">库存 {{item.stock}}</text>
        </view>
        <text class="name">{{item.name}}</text>
        <text class="spec">{{item.specText}}</text>
        <text class="lead">{{item.leadText}}</text>
        <view class="product-bottom">
          <text class="price">¥{{item.priceText}}</text>
          <view class="cart-plus-btn" catchtap="onCartPlusTap" data-id="{{item.id}}">
            <text class="cart-plus-icon">+</text>
          </view>
        </view>
      </view>
      <view wx:if="{{products.length === 0}}" class="empty">{{emptyText}}</view>
    </scroll-view>
  </view>

  <!-- 商品规格选择弹框 -->
  <product-action-sheet
    visible="{{actionSheetVisible}}"
    product="{{actionSheetProduct}}"
    isInstitution="{{isInstitution}}"
    bind:close="onActionSheetClose"
    bind:addcart="onActionSheetAddCart"
    bind:buynow="onActionSheetBuyNow"
  />
</view>
