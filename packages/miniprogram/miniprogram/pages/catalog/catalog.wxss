.page {
  height: 100vh;
  padding: 24rpx 24rpx 0;
  background:
    radial-gradient(circle at 8% 0%, rgba(10, 110, 124, 0.14), transparent 34%),
    linear-gradient(180deg, #f4fbfa 0%, #ffffff 40%);
  box-sizing: border-box;
}

.catalog-hero {
  padding: 30rpx;
  border-radius: 34rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #063e46, #0a6e7c 58%, #159c88);
  box-shadow: 0 20rpx 50rpx rgba(6, 62, 70, 0.18);
}

.hero-eyebrow {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.74);
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 900;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
  line-height: 1.65;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.summary-card {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 34rpx rgba(23, 61, 64, 0.07);
}

.summary-value {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #0a6e7c;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  color: #173236;
  font-size: 24rpx;
  font-weight: 800;
}

.summary-desc {
  display: block;
  margin-top: 8rpx;
  color: #78888a;
  font-size: 20rpx;
  line-height: 1.45;
}

.quick-filters {
  margin: 18rpx 0 14rpx;
  white-space: nowrap;
}

.filter-pill {
  display: inline-block;
  margin-right: 14rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  color: #627678;
  font-size: 24rpx;
  background: #edf4f3;
}

.filter-pill.active {
  color: #ffffff;
  font-weight: 800;
  background: #0a6e7c;
}

.layout {
  display: flex;
  height: calc(100vh - 390rpx);
  gap: 16rpx;
}

.sidebar {
  width: 184rpx;
  padding: 10rpx 0 28rpx;
  border-radius: 30rpx;
  background: rgba(240, 247, 246, 0.92);
}

.sidebar-item {
  margin: 10rpx 14rpx;
  padding: 24rpx 18rpx;
  border-radius: 22rpx;
}

.sidebar-item.active {
  background: linear-gradient(135deg, #0a6e7c, #0d8f81);
  box-shadow: 0 16rpx 36rpx rgba(10, 110, 124, 0.2);
}

.sidebar-name {
  display: block;
  color: #5d7175;
  font-size: 24rpx;
  text-align: center;
}

.sidebar-item.active .sidebar-name {
  color: #ffffff;
  font-weight: 800;
}

.content {
  flex: 1;
  padding: 2rpx 4rpx 30rpx;
  box-sizing: border-box;
}

.product-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 44rpx rgba(23, 61, 64, 0.08);
}

.product-item.warn {
  box-shadow: 0 16rpx 44rpx rgba(183, 119, 0, 0.1);
}

.product-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #0a6e7c;
  font-size: 20rpx;
  font-weight: 800;
  background: #def7ed;
}

.stock {
  color: #8b999b;
  font-size: 20rpx;
}

.stock.warn {
  color: #b77700;
  font-weight: 700;
}

.name {
  display: block;
  margin-top: 18rpx;
  color: #173236;
  font-size: 29rpx;
  font-weight: 800;
}

.spec {
  display: block;
  margin-top: 10rpx;
  color: #768789;
  font-size: 22rpx;
}

.lead {
  display: block;
  margin-top: 12rpx;
  color: #617477;
  font-size: 22rpx;
  line-height: 1.5;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.price {
  color: #ba7800;
  font-size: 32rpx;
  font-weight: 900;
}

.cta {
  color: #0a6e7c;
  font-size: 22rpx;
  font-weight: 800;
}

.empty {
  padding: 120rpx 0;
  color: #8b999b;
  font-size: 24rpx;
  text-align: center;
}
