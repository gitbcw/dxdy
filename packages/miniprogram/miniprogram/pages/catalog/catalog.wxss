.page {
  height: 100vh;
  background: linear-gradient(180deg, #f3fbfa 0%, #ffffff 34%);
}

.catalog-hero {
  padding: 28rpx 24rpx 18rpx;
}

.hero-title {
  display: block;
  color: #173236;
  font-size: 38rpx;
  font-weight: 900;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #738487;
  font-size: 23rpx;
  line-height: 1.6;
}

.layout {
  display: flex;
  height: calc(100vh - 150rpx);
}

.sidebar {
  width: 200rpx;
  padding: 10rpx 0 28rpx;
  background: rgba(240, 247, 246, 0.92);
}

.sidebar-item {
  margin: 10rpx 14rpx;
  padding: 24rpx 18rpx;
  border-radius: 22rpx;
}

.sidebar-item.active {
  background: linear-gradient(135deg, #0a6e7c, #0d8f81);
  box-shadow: 0 16rpx 36rpx rgba(10, 110, 124, 0.2);
}

.sidebar-name {
  display: block;
  color: #5d7175;
  font-size: 24rpx;
  text-align: center;
}

.sidebar-item.active .sidebar-name {
  color: #ffffff;
  font-weight: 800;
}

.content {
  flex: 1;
  padding: 8rpx 18rpx 30rpx;
  box-sizing: border-box;
}

.product-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 44rpx rgba(23, 61, 64, 0.08);
}

.product-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #0a6e7c;
  font-size: 20rpx;
  font-weight: 800;
  background: #def7ed;
}

.stock {
  color: #8b999b;
  font-size: 20rpx;
}

.name {
  display: block;
  margin-top: 20rpx;
  color: #173236;
  font-size: 29rpx;
  font-weight: 800;
}

.spec {
  display: block;
  margin-top: 10rpx;
  color: #768789;
  font-size: 22rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
}

.price {
  color: #ba7800;
  font-size: 32rpx;
  font-weight: 900;
}

.cta {
  color: #0a6e7c;
  font-size: 22rpx;
  font-weight: 800;
}

.empty {
  padding: 120rpx 0;
  color: #8b999b;
  font-size: 24rpx;
  text-align: center;
}
