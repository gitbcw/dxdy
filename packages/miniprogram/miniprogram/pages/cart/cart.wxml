<view class="cart-page">
  <!-- 顶部导航 -->
  <view class="cart-header">
    <view style="display: flex; align-items: center;">
      <text class="cart-title">购物车</text>
      <text class="cart-count">{{items.length}} 件商品</text>
    </view>
    <view class="clear-btn" bindtap="onClearCart">清空</view>
  </view>

  <!-- 空购物车 -->
  <view wx:if="{{isEmpty}}" class="empty-cart">
    <view class="empty-icon-box">
      <view class="empty-icon-shape"></view>
    </view>
    <text class="empty-text">购物车是空的</text>
    <text class="empty-hint">快去挑选心仪的商品吧</text>
    <view class="shop-btn" bindtap="onShop">去逛逛</view>
  </view>

  <!-- 购物车列表 -->
  <view wx:else class="cart-list">
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="cart-item"
    >
      <view class="item-image">
        <view class="image-placeholder">
          <view class="placeholder-hexagon"></view>
        </view>
      </view>
      <view class="item-content">
        <view>
          <text class="item-name">{{item.name}}</text>
          <text class="item-spec">{{item.specs[0].value}}</text>
        </view>
        <view class="item-bottom">
          <view class="item-price">
            <text class="price-current">{{item.lineTotal}}</text>
            <text class="price-unit">小计</text>
          </view>
          <view class="quantity-control">
            <view class="qty-btn" data-index="{{index}}" data-delta="{{-1}}" bindtap="onQuantityChange">
              <text class="qty-icon">−</text>
            </view>
            <text class="qty-value">{{item.quantity}}</text>
            <view class="qty-btn" data-index="{{index}}" data-delta="{{1}}" bindtap="onQuantityChange">
              <text class="qty-icon">+</text>
            </view>
          </view>
        </view>
      </view>
      <view class="item-remove" data-index="{{index}}" bindtap="onRemove">
        <text class="remove-icon">×</text>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view wx:if="{{!isEmpty}}" class="cart-footer">
    <view class="footer-left">
      <text class="total-label">合计金额</text>
      <view class="total-amount">
        <text class="total-symbol">¥</text>
        <text class="total-value">{{total}}</text>
      </view>
    </view>
    <view class="footer-right">
      <view class="settlement-btn" bindtap="onCheckout">去结算</view>
    </view>
  </view>
</view>
