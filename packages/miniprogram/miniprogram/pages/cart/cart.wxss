/* cart.wxss - 大熊动医华南医学检验实验室 - Cart Page */
/*Design: Clinical Precision meets Warm Professionalism*/

.cart-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 160rpx;
}

/* ============ 顶部导航 ============ */
.cart-header {
  background: var(--bg-card);
  padding: 32rpx 32rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow-sm);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid var(--border-color);
}

.cart-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.cart-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-left: 16rpx;
}

.clear-btn {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 10rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-section);
  transition: all 0.2s ease;
}

.clear-btn:active {
  background: rgba(220, 53, 69, 0.1);
  color: var(--color-error);
}

/* ============ 购物车列表 ============ */
.cart-list {
  padding: 20rpx;
}

.cart-item {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  gap: 16rpx;
  transition: all 0.2s ease;
  border: 1rpx solid var(--border-color);
  position: relative;
}

.cart-item:active {
  transform: scale(0.99);
}

/* 商品图片 */
.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--bg-section);
}

.image-placeholder {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

.placeholder-hexagon {
  width: 100%;
  height: 100%;
  border: 2rpx solid var(--color-primary);
  border-radius: 6rpx;
  transform: rotate(45deg);
  opacity: 0.3;
}

/* 商品信息 */
.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-spec {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* 数量和价格 */
.item-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 12rpx;
}

.item-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-current {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-accent);
}

.price-current::before {
  content: '¥';
  font-size: 22rpx;
  font-weight: 600;
}

.price-unit {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-left: 4rpx;
}

/* 数量控制器 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 0;
  background: var(--bg-section);
  border-radius: var(--radius-md);
  padding: 4rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  background: var(--bg-card);
  border-radius: var(--radius-sm);
  transition: all 0.15s ease;
}

.qty-btn:active {
  transform: scale(0.92);
  background: var(--color-primary);
}

.qty-btn:active image {
  filter: brightness(10);
}

.qty-value {
  min-width: 48rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 删除按钮 */
.item-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  background: var(--bg-section);
  border-radius: var(--radius-sm);
  transition: all 0.2s ease;
}

.item-remove:active {
  background: rgba(220, 53, 69, 0.1);
  color: var(--color-error);
}

/* ============ 底部结算栏 ============ */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(10, 110, 124, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
  border-top: 1rpx solid var(--border-color);
}

.footer-left {
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.total-amount {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.total-symbol {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.total-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-accent);
}

.footer-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.settlement-btn {
  background: var(--color-primary);
  color: var(--text-inverse);
  padding: 24rpx 56rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: var(--shadow-md);
  transition: all 0.2s ease;
}

.settlement-btn:active {
  transform: scale(0.97);
  background: var(--color-primary-dark);
}

/* ============ 空购物车 ============ */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon-box {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  position: relative;
}

.empty-icon-shape {
  width: 100%;
  height: 100%;
  border: 3rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  transform: rotate(45deg);
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 48rpx;
}

.shop-btn {
  background: var(--color-primary);
  color: var(--text-inverse);
  padding: 24rpx 64rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: var(--shadow-md);
  transition: all 0.2s ease;
}

.shop-btn:active {
  transform: scale(0.97);
  background: var(--color-primary-dark);
}

/* ============ 动画 ============ */
.cart-header {
  animation: fadeIn 0.3s ease;
}

.cart-item {
  animation: fadeInUp 0.4s ease backwards;
}

.cart-item:nth-child(1) { animation-delay: 0.05s; }
.cart-item:nth-child(2) { animation-delay: 0.1s; }
.cart-item:nth-child(3) { animation-delay: 0.15s; }
.cart-item:nth-child(4) { animation-delay: 0.2s; }
.cart-item:nth-child(5) { animation-delay: 0.25s; }
