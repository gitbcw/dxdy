<view class="page">
  <view class="hero">
    <view class="hero-top">
      <text class="header-title">先把今天最急的单发出去</text>
      <view class="header-badge" wx:if="{{pendingCount > 0}}">
        <text class="badge-count">{{pendingCount}}</text>
      </view>
    </view>
    <text class="hero-subtitle">待发货、换货优先单和物流同步都放在一页里，减少制单员来回切换页面。</text>
  </view>

  <view class="summary-grid">
    <view wx:for="{{summaryCards}}" wx:key="label" class="summary-card">
      <text class="summary-value">{{item.value}}</text>
      <text class="summary-label">{{item.label}}</text>
      <text class="summary-desc">{{item.desc}}</text>
    </view>
  </view>

  <view wx:if="{{isEmpty}}" class="empty-state">
    <image class="empty-icon" src="{{iconClock}}" mode="aspectFit" />
    <text class="empty-text">暂无待处理订单</text>
    <text class="empty-hint">所有订单已处理完毕</text>
  </view>

  <view wx:else class="order-list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card" data-id="{{item.id}}" bindtap="onOrderTap">
        <view class="order-header">
          <view>
            <text class="order-id">订单号：{{item.orderNo}}</text>
            <text class="order-badge">{{item.badgeText}}</text>
          </view>
          <view class="status-tag {{item.type === 'exchange' ? 'tag-booking' : 'tag-normal'}}">
            <image wx:if="{{item.type === 'exchange'}}" src="{{iconExchange}}" mode="aspectFit" style="width:20rpx;height:20rpx;" />
            <text>{{item.type === 'exchange' ? '换货' : '普通'}}</text>
          </view>
        </view>

        <view class="order-body">
          <view wx:for="{{item.items}}" wx:for-item="prod" wx:key="name" class="order-item">
            <view class="item-icon">
              <image src="{{iconClock}}" mode="aspectFit" style="width:28rpx;height:28rpx;" />
            </view>
            <view class="item-details">
              <text class="item-name">{{prod.name}}</text>
              <text class="item-qty">{{prod.specs}} · x{{prod.quantity}}</text>
            </view>
          </view>
        </view>

        <text class="helper-text">{{item.helperText}}</text>

        <view class="order-customer">
          <view class="customer-row">
            <text class="customer-label">客户姓名</text>
            <text class="customer-value">{{item.customerName}}</text>
          </view>
          <view class="customer-row">
            <text class="customer-label">联系电话</text>
            <text class="customer-value">{{item.customerPhone}}</text>
          </view>
          <view class="customer-row">
            <text class="customer-label">收货地址</text>
            <text class="customer-value address">{{item.address}}</text>
          </view>
        </view>

        <view class="order-footer">
          <view class="assign-time">
            <image src="{{iconClock}}" mode="aspectFit" style="width:24rpx;height:24rpx;opacity:0.6;" />
            <text>指派时间：{{item.assignedAt}}</text>
          </view>
          <view class="view-detail">
            <text>查看详情</text>
            <text class="arrow">›</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
