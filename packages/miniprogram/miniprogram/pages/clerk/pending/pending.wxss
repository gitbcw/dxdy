.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(10, 110, 124, 0.12), transparent 34%),
    linear-gradient(180deg, #f4fbfa 0%, #ffffff 100%);
  box-sizing: border-box;
}

.hero {
  padding: 30rpx;
  border-radius: 32rpx;
  color: #ffffff;
  background: linear-gradient(160deg, #063e46 0%, #0a6e7c 58%, #0d8a9a 100%);
  box-shadow: 0 20rpx 48rpx rgba(6, 62, 70, 0.18);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.header-title {
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 900;
  color: #ffffff;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
  line-height: 1.65;
}

.header-badge {
  background: #d4a853;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  min-width: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-count {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.summary-card {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 34rpx rgba(23, 61, 64, 0.07);
}

.summary-value {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #0a6e7c;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  color: #173236;
  font-size: 24rpx;
  font-weight: 800;
}

.summary-desc {
  display: block;
  margin-top: 8rpx;
  color: #78888a;
  font-size: 20rpx;
  line-height: 1.45;
}

.order-list {
  margin-top: 18rpx;
}

.order-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 14rpx 36rpx rgba(23, 61, 64, 0.07);
}

.order-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx dashed #dbe7e6;
}

.order-id {
  display: block;
  font-size: 24rpx;
  color: #6d7f82;
  font-family: monospace;
}

.order-badge {
  display: inline-block;
  margin-top: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #0a6e7c;
  font-size: 20rpx;
  font-weight: 800;
  background: #def7ed;
}

.status-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.status-tag.tag-normal {
  background: rgba(10, 110, 124, 0.12);
  color: #0a6e7c;
}

.status-tag.tag-booking {
  background: rgba(212, 168, 83, 0.15);
  color: #d4a853;
}

.order-body {
  padding: 10rpx 0 0;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.item-icon {
  width: 56rpx;
  height: 56rpx;
  background: #f3f8f7;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-details {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #173236;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-qty {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #6d7f82;
}

.helper-text {
  display: block;
  margin-top: 10rpx;
  color: #607174;
  font-size: 22rpx;
  line-height: 1.5;
}

.order-customer {
  background: #f6faf9;
  border-radius: 22rpx;
  padding: 16rpx 20rpx;
  margin: 16rpx 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.customer-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.customer-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #6d7f82;
}

.customer-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #173236;
  text-align: right;
}

.customer-value.address {
  line-height: 1.5;
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx dashed #dbe7e6;
}

.assign-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #6d7f82;
}

.view-detail {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #0a6e7c;
}

.arrow {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.4;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #173236;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #7b8b8d;
}
