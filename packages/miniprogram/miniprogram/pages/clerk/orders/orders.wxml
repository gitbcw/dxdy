<view class="page">
  <!-- 页面顶部：标题 -->
  <view class="page-header">
    <text class="header-title">全部订单</text>
  </view>

  <!-- Tab 栏 -->
  <view class="tab-bar">
    <block wx:for="{{tabs}}" wx:key="key">
      <view
        class="tab-item {{activeTab === item.key ? 'tab-active' : ''}}"
        data-tab="{{item.key}}"
        bindtap="onTabChange"
      >
        <text class="tab-label">{{item.label}}</text>
      </view>
    </block>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{isEmpty}}" class="empty-state">
    <image class="empty-icon" src="{{iconEmpty}}" mode="aspectFit" />
    <text class="empty-text">暂无订单</text>
    <text class="empty-hint">当前分类下没有订单</text>
  </view>

  <!-- 订单列表 -->
  <view wx:else class="order-list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card" data-id="{{item.id}}" bindtap="onOrderTap">
        <!-- 订单头部：订单号 + 状态标签 -->
        <view class="order-header">
          <text class="order-id">订单号：{{item.orderNo}}</text>
          <view class="status-tag {{item.type === 'exchange' ? 'tag-booking' : 'tag-normal'}}">
            <image wx:if="{{item.type === 'exchange'}}" src="{{iconRefresh}}" mode="aspectFit" style="width:20rpx;height:20rpx;" />
            <text>{{item.type === 'exchange' ? '换货' : '普通'}}</text>
          </view>
        </view>

        <!-- 商品信息 -->
        <view class="order-body">
          <view wx:for="{{item.items}}" wx:for-item="prod" wx:key="index" class="order-item">
            <view class="item-icon">
              <image src="{{iconClock}}" mode="aspectFit" style="width:28rpx;height:28rpx;" />
            </view>
            <view class="item-details">
              <text class="item-name">{{prod.name}}</text>
              <text class="item-qty">x{{prod.quantity}} · {{prod.specs}}</text>
            </view>
          </view>
        </view>

        <!-- 客户信息 -->
        <view class="order-customer">
          <view class="customer-row">
            <text class="customer-label">客户姓名</text>
            <text class="customer-value">{{item.customerName}}</text>
          </view>
          <view class="customer-row">
            <text class="customer-label">联系电话</text>
            <text class="customer-value">{{item.customerPhone}}</text>
          </view>
        </view>

        <!-- 快递信息（仅已发货订单显示） -->
        <view wx:if="{{item.status === 'shipped' && item.expressCompany}}" class="express-info">
          <view class="express-row">
            <text class="express-label">快递公司</text>
            <text class="express-value">{{item.expressCompany}}</text>
          </view>
          <view class="express-row">
            <text class="express-label">快递单号</text>
            <text class="express-value express-no">{{item.expressNo}}</text>
          </view>
        </view>

        <!-- 底部：时间 + 查看详情 -->
        <view class="order-footer">
          <view class="assign-time">
            <image src="{{iconClock}}" mode="aspectFit" style="width:24rpx;height:24rpx;opacity:0.6;" />
            <text>{{item.status === 'shipped' && item.shippedAt ? '发货时间：' + item.shippedAt : '指派时间：' + item.assignedAt}}</text>
          </view>
          <view class="view-detail">
            <text>查看详情</text>
            <text class="arrow">›</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>