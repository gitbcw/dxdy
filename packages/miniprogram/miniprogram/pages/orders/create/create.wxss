.page {
  min-height: 100vh;
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(10, 110, 124, 0.14), transparent 34%),
    linear-gradient(180deg, #f3fbfa 0%, #ffffff 100%);
}

.content {
  padding: 24rpx;
}

.hero-card,
.card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 42rpx rgba(23, 61, 64, 0.08);
}

.hero-card {
  color: #ffffff;
  background: linear-gradient(135deg, #083d45 0%, #0a6e7c 55%, #159c88 100%);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.name {
  display: block;
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.product-tag {
  flex-shrink: 0;
  align-self: flex-start;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #083d45;
  font-size: 22rpx;
  font-weight: 800;
  background: #dff7ed;
}

.desc {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.84);
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.74);
}

.type-switch {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.type-item {
  padding: 24rpx;
  border-radius: 28rpx;
  background: #f4f7f7;
}

.type-item.active {
  background: linear-gradient(135deg, #dff7ed, #ffffff);
  box-shadow: inset 0 0 0 2rpx rgba(10, 110, 124, 0.2);
}

.type-item.disabled {
  opacity: 0.45;
}

.type-title {
  display: block;
  color: #173236;
  font-size: 28rpx;
  font-weight: 800;
}

.type-desc {
  display: block;
  margin-top: 8rpx;
  color: #78888a;
  font-size: 22rpx;
}

.row,
.price-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  color: #173236;
  font-size: 28rpx;
  font-weight: 800;
}

.hint {
  display: block;
  margin-top: 8rpx;
  color: #849295;
  font-size: 21rpx;
}

.quantity {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 16rpx;
  color: #0a6e7c;
  font-size: 34rpx;
  font-weight: 700;
  background: #e9f5f3;
}

.num {
  margin: 0 24rpx;
  color: #173236;
  font-size: 34rpx;
  font-weight: 800;
}

.price-line {
  margin-top: 14rpx;
  color: #6f8183;
  font-size: 24rpx;
}

.price-line.strong {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #edf2f1;
  color: #173236;
  font-size: 28rpx;
  font-weight: 800;
}

.card-title {
  display: block;
  margin-bottom: 18rpx;
  color: #173236;
  font-size: 30rpx;
  font-weight: 900;
}

.field {
  margin-top: 18rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #6f8183;
  font-size: 23rpx;
}

.field-input {
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  background: #f6faf9;
}

.address-box,
.rule-box {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6faf9;
}

.address-title,
.rule-title {
  display: block;
  color: #173236;
  font-size: 24rpx;
  font-weight: 800;
}

.address-text,
.rule-text {
  display: block;
  margin-top: 10rpx;
  color: #728386;
  font-size: 23rpx;
  line-height: 1.55;
}

.pay-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.pay-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6faf9;
  color: #6f8183;
  font-size: 24rpx;
}

.pay-item.active {
  color: #0a6e7c;
  box-shadow: inset 0 0 0 2rpx rgba(10, 110, 124, 0.18);
}

.rule-box {
  margin-top: 18rpx;
}

.footer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 26rpx rgba(16, 45, 48, 0.08);
}

.footer-label {
  display: block;
  color: #7b8b8d;
  font-size: 22rpx;
}

.total {
  display: block;
  margin-top: 8rpx;
  color: #b77800;
  font-size: 38rpx;
  font-weight: 900;
}

.submit-btn {
  padding: 24rpx 44rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}
