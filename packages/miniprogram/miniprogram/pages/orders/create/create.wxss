.page { min-height: 100vh; background: #f5f5f5; }
.content { padding: 16rpx; padding-bottom: 140rpx; }
.product-section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.name { display: block; font-size: 32rpx; font-weight: 600; }
.spec { display: block; font-size: 24rpx; color: #999; margin-top: 8rpx; }
.price { display: block; font-size: 36rpx; color: #e4393c; font-weight: 600; margin-top: 16rpx; }
.quantity-section { display: flex; justify-content: space-between; align-items: center; background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.label { font-size: 28rpx; color: #333; }
.quantity { display: flex; align-items: center; }
.btn { width: 56rpx; height: 56rpx; line-height: 56rpx; text-align: center; border: 1rpx solid #ddd; border-radius: 8rpx; font-size: 32rpx; }
.num { margin: 0 24rpx; font-size: 32rpx; font-weight: 500; }
.remark-section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.remark-input { margin-top: 16rpx; font-size: 28rpx; }
.footer { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; justify-content: space-between; padding: 20rpx 24rpx; background: #fff; border-top: 1rpx solid #eee; }
.total { font-size: 32rpx; font-weight: 600; }
.submit-btn { background: #333; color: #fff; padding: 20rpx 56rpx; border-radius: 32rpx; font-size: 30rpx; font-weight: 500; }
