.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(10, 110, 124, 0.14), transparent 34%),
    linear-gradient(180deg, #f3fbfa 0%, #ffffff 100%);
  box-sizing: border-box;
}

.page-hero,
.detail-hero {
  padding: 32rpx;
  border-radius: 34rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #063e46, #0a6e7c 60%, #159c88);
  box-shadow: 0 22rpx 58rpx rgba(6, 62, 70, 0.18);
}

.hero-title,
.detail-title {
  display: block;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-subtitle,
.detail-desc {
  display: block;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 1.65;
}

.tabs {
  margin: 24rpx 0 12rpx;
  white-space: nowrap;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.summary-card {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 34rpx rgba(23, 61, 64, 0.07);
}

.summary-value {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #0a6e7c;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #173236;
}

.summary-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.45;
  color: #7b8a8c;
}

.tab {
  display: inline-block;
  margin-right: 14rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  color: #607477;
  font-size: 24rpx;
  background: #edf4f3;
}

.tab.active {
  color: #ffffff;
  font-weight: 800;
  background: #0a6e7c;
}

.empty {
  padding: 160rpx 0;
  color: #839294;
  text-align: center;
}

.order-card,
.card,
.flow-card {
  margin-top: 18rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 44rpx rgba(23, 61, 64, 0.08);
}

.order-header,
.order-footer,
.detail-top,
.detail-amount,
.info-row,
.item-row,
.price-log {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.order-id {
  display: block;
  color: #708184;
  font-size: 22rpx;
  font-family: monospace;
}

.order-id.light {
  color: rgba(255, 255, 255, 0.7);
}

.date {
  display: block;
  margin-top: 8rpx;
  color: #99a5a7;
  font-size: 21rpx;
}

.order-status {
  flex-shrink: 0;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  color: #0a6e7c;
  font-size: 22rpx;
  font-weight: 800;
  background: #dff7ed;
}

.product-box {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f6faf9;
}

.priority-row {
  margin-top: 18rpx;
}

.priority-pill {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #0a6e7c;
  font-size: 20rpx;
  font-weight: 800;
  background: #def7ed;
}

.priority-note {
  display: block;
  margin-top: 10rpx;
  color: #607174;
  font-size: 22rpx;
  line-height: 1.5;
}

.product-name,
.item-name {
  display: block;
  color: #173236;
  font-size: 28rpx;
  font-weight: 800;
}

.product-spec,
.item-spec {
  display: block;
  margin-top: 8rpx;
  color: #7d8d8f;
  font-size: 22rpx;
}

.notice {
  display: block;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  color: #0a6e7c;
  font-size: 22rpx;
  line-height: 1.5;
  background: #e2f7ef;
}

.notice.amber {
  color: #7c5200;
  background: #fff1cd;
}

.notice.in-card {
  margin-top: 18rpx;
}

.order-footer {
  align-items: center;
  margin-top: 22rpx;
}

.amount,
.item-price {
  color: #b77700;
  font-size: 32rpx;
  font-weight: 900;
}

.detail-link {
  color: #0a6e7c;
  font-size: 24rpx;
  font-weight: 800;
}

.back-btn {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #063e46;
  font-size: 22rpx;
  font-weight: 800;
  background: #dff7ed;
}

.detail-amount {
  align-items: center;
  margin-top: 28rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.12);
}

.detail-amount text:last-child {
  font-size: 38rpx;
  font-weight: 900;
  color: #f4d27c;
}

.card-title {
  display: block;
  margin-bottom: 22rpx;
  color: #173236;
  font-size: 30rpx;
  font-weight: 900;
}

.flow-line {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.flow-step {
  flex: 1;
  text-align: center;
}

.flow-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  margin: 0 auto 12rpx;
  border-radius: 999rpx;
  color: #8da0a3;
  font-size: 22rpx;
  font-weight: 900;
  background: #edf2f1;
}

.flow-dot.active {
  color: #ffffff;
  background: #0a6e7c;
}

.flow-label {
  color: #53696d;
  font-size: 21rpx;
}

.item-row,
.price-log,
.info-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf2f1;
}

.item-row:last-child,
.price-log:last-child,
.info-row:last-child {
  border-bottom: 0;
}

.info-row text:first-child {
  flex-shrink: 0;
  color: #7b8b8d;
  font-size: 23rpx;
}

.info-row text:last-child {
  flex: 1;
  color: #173236;
  font-size: 23rpx;
  line-height: 1.5;
  text-align: right;
}

.action-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  gap: 18rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 26rpx rgba(16, 45, 48, 0.08);
}

.action-btn {
  flex: 1;
  padding: 22rpx;
  border-radius: 999rpx;
  color: #0a6e7c;
  font-size: 28rpx;
  font-weight: 800;
  text-align: center;
  background: #e8f5f3;
}

.action-btn.primary {
  color: #ffffff;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}
