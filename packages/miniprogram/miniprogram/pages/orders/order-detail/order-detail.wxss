.page { min-height: 100vh; background: #f5f5f5; padding: 16rpx; }
.empty { text-align: center; padding: 200rpx 0; color: #999; }
.order-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.order-header { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.order-id { font-size: 26rpx; color: #999; font-family: monospace; }
.order-status { font-size: 26rpx; color: #333; font-weight: 500; }
.order-body { padding: 8rpx 0; border-top: 1rpx solid #f0f0f0; border-bottom: 1rpx solid #f0f0f0; }
.product-text { display: block; font-size: 28rpx; color: #333; padding: 4rpx 0; }
.order-footer { display: flex; justify-content: space-between; margin-top: 16rpx; }
.amount { font-size: 30rpx; color: #e4393c; font-weight: 600; }
.date { font-size: 24rpx; color: #999; }
