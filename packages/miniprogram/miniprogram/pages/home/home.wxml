<view class="page">
  <view wx:if="{{banner}}" class="cert-banner {{banner.status}}">
    <view class="banner-main">
      <text class="banner-text">{{banner.text}}</text>
      <view wx:if="{{banner.actionText}}" class="banner-action" bindtap="onBannerAction">{{banner.actionText}}</view>
    </view>
    <text wx:if="{{banner.rejectReason}}" class="banner-reason">驳回原因：{{banner.rejectReason}}</text>
  </view>

  <view class="home-header">
    <text class="header-name">{{displayName}}</text>
    <view class="identity-tag {{identityTagClass}}">{{identityTag}}</view>
  </view>

  <view class="search-bar">
    <text class="search-icon">搜</text>
    <input
      class="search-input"
      placeholder="{{searchPlaceholder}}"
      value="{{searchKeyword}}"
      confirm-type="search"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
    />
    <view wx:if="{{searchKeyword}}" class="search-clear" catchtap="onSearchClear">×</view>
    <view class="search-submit" bindtap="onSearchTap">搜索</view>
  </view>

  <view class="panel">
    <view class="section-head">
      <text class="section-title">快捷入口</text>
    </view>
    <view class="quick-row">
      <view
        wx:for="{{quickActions}}"
        wx:key="title"
        class="quick-item"
        data-action="{{item.action}}"
        bindtap="onQuickActionTap"
      >
        <view class="quick-icon-sm">{{item.icon}}</view>
        <text class="quick-title-sm">{{item.title}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{taskCards.length > 0}}" class="panel">
    <view class="section-head">
      <text class="section-title">待办事项</text>
    </view>
    <view class="task-list">
      <view
        wx:for="{{taskCards}}"
        wx:key="title"
        class="task-card"
        data-action="{{item.action}}"
        bindtap="onTaskTap"
      >
        <view class="task-head">
          <text class="task-badge">{{item.badge}}</text>
          <text class="task-action">{{item.actionText}}</text>
        </view>
        <text class="task-title">{{item.title}}</text>
        <text class="task-desc">{{item.desc}}</text>
        <text class="task-meta">{{item.meta}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{boardItems.length > 0}}" class="panel">
    <view class="section-head">
      <text class="section-title">{{boardTitle}}</text>
      <text class="section-more" bindtap="onBoardMoreTap">{{boardMoreText}} ></text>
    </view>
    <view class="board-list">
      <view
        wx:for="{{boardItems}}"
        wx:key="id"
        class="board-card"
        data-idx="{{index}}"
        bindtap="onBoardItemTap"
      >
        <view class="board-row">
          <text class="board-badge">{{item.badge}}</text>
          <view wx:if="{{item.type === 'product'}}" class="board-cart" data-idx="{{index}}" catchtap="onBoardCartTap">
            <text class="cart-plus">+</text>
          </view>
          <text wx:elif="{{item.actionText}}" class="board-action">{{item.actionText}}</text>
        </view>
        <text class="board-title">{{item.title}}</text>
        <text class="board-desc">{{item.desc}}</text>
        <text class="board-meta">{{item.meta}}</text>
      </view>
    </view>
  </view>

  <product-action-sheet
    visible="{{actionSheetVisible}}"
    product="{{actionSheetProduct}}"
    isInstitution="{{isInstitution}}"
    bind:close="onActionSheetClose"
    bind:addcart="onActionSheetAddCart"
    bind:buynow="onActionSheetBuyNow"
  />
</view>
