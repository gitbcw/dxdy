<view class="page">
  <view class="hero">
    <view class="hero-top">
      <view class="hero-copy">
        <text class="eyebrow">大熊动医华南医学检验实验室</text>
        <text class="title">{{pageTitle}}</text>
      </view>
      <view class="role-pill">{{roleLabel}}</view>
    </view>
    <text class="subtitle">{{heroSubtitle}}</text>
    <view class="hero-actions">
      <view class="primary-action" bindtap="onPrimaryAction">{{primaryActionText}}</view>
      <view class="ghost-action" bindtap="onSecondaryAction">{{secondaryActionText}}</view>
    </view>
  </view>

  <view class="identity-card">
    <view class="identity-main">
      <view class="avatar">{{avatarText}}</view>
      <view class="identity-copy">
        <text class="identity-name">{{displayName}}</text>
        <text class="identity-desc">{{identityDesc}}</text>
      </view>
    </view>
    <view class="identity-status {{verificationClass}}">{{verificationText}}</view>
  </view>

  <view class="summary-grid">
    <view wx:for="{{summaryCards}}" wx:key="label" class="summary-card">
      <text class="summary-value">{{item.value}}</text>
      <text class="summary-label">{{item.label}}</text>
      <text class="summary-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="panel">
    <view class="section-head">
      <text class="section-title">现在先做什么</text>
      <text class="section-note">把最该处理的动作放到首屏</text>
    </view>
    <view class="task-list">
      <view
        wx:for="{{taskCards}}"
        wx:key="title"
        class="task-card"
        data-action="{{item.action}}"
        bindtap="onTaskTap"
      >
        <view class="task-head">
          <text class="task-badge">{{item.badge}}</text>
          <text class="task-action">{{item.actionText}}</text>
        </view>
        <text class="task-title">{{item.title}}</text>
        <text class="task-desc">{{item.desc}}</text>
        <text class="task-meta">{{item.meta}}</text>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="section-head">
      <text class="section-title">快捷入口</text>
      <text class="section-note">按角色直接去目标页</text>
    </view>
    <view class="quick-grid">
      <view
        wx:for="{{quickActions}}"
        wx:key="title"
        class="quick-card"
        data-action="{{item.action}}"
        bindtap="onQuickActionTap"
      >
        <view class="quick-icon">{{item.icon}}</view>
        <text class="quick-title">{{item.title}}</text>
        <text class="quick-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="section-head">
      <text class="section-title">{{boardTitle}}</text>
      <text class="section-more" bindtap="onBoardMoreTap">{{boardMoreText}} ></text>
    </view>
    <view class="board-list">
      <view
        wx:for="{{boardItems}}"
        wx:key="title"
        class="board-card"
        data-action="{{item.action}}"
        bindtap="onBoardItemTap"
      >
        <view class="board-row">
          <text class="board-badge">{{item.badge}}</text>
          <text class="board-action">{{item.actionText}}</text>
        </view>
        <text class="board-title">{{item.title}}</text>
        <text class="board-desc">{{item.desc}}</text>
        <text class="board-meta">{{item.meta}}</text>
      </view>
    </view>
  </view>
</view>
