.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background:
    radial-gradient(circle at 8% 0%, rgba(12, 112, 124, 0.14), transparent 34%),
    linear-gradient(180deg, #f4fbfa 0%, #f8f7f3 42%, #ffffff 100%);
  box-sizing: border-box;
}

/* ── 顶部：名称 + 身份标签 ── */
.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 4rpx;
}

.header-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #173236;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 60%;
}

.identity-tag {
  flex-shrink: 0;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.identity-tag.verified {
  color: #0d5d4d;
  background: #dff7ed;
}

.identity-tag.default {
  color: #5f6f71;
  background: #e8f0f2;
}

.identity-tag.staff {
  color: #063e46;
  background: #d9f4ea;
}

/* ── 搜索栏 ── */
.search-bar {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(10, 110, 124, 0.1);
}

.search-icon {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #0a6e7c, #159888);
}

.search-placeholder {
  color: #a0aaac;
  font-size: 26rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #173236;
}

.search-clear {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 28rpx;
  color: #7a8a8d;
  background: #eef4f4;
}

.search-submit {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #0a6e7c, #159888);
}

/* ── 认证横幅 ── */
.cert-banner {
  margin: -24rpx -24rpx 20rpx;
  padding: calc(14rpx + env(safe-area-inset-top)) 24rpx 14rpx;
  border-radius: 0;
  background: rgba(236, 248, 246, 0.98);
  box-shadow: none;
}

.cert-banner.none {
  border-left: 0;
  background: #ecf8f6;
}

.cert-banner.pending {
  border-left: 0;
  background: #fff8df;
}

.cert-banner.rejected {
  border-left: 0;
  background: #fff0ee;
}

.banner-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.banner-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: #173236;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.banner-reason {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #e54d42;
}

.banner-action {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}

/* ── 快捷入口（紧凑） ── */
.quick-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx 0;
  padding: 24rpx 0 8rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 16rpx;
}

.quick-icon-sm {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #0a6e7c, #159888);
}

.quick-title-sm {
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #173236;
}

/* ── 面板通用 ── */
.panel {
  margin-top: 22rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(9, 92, 103, 0.09);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(23, 61, 64, 0.08);
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #173236;
}

.section-more {
  font-size: 23rpx;
  line-height: 1.4;
  color: #0a6e7c;
}

/* ── 待办任务卡片 ── */
.task-list,
.board-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-card,
.board-card {
  padding: 24rpx;
  border-radius: 28rpx;
}

.task-card {
  color: #ffffff;
  background: linear-gradient(135deg, #093f47, #0c6f7d 58%, #159888 100%);
}

.board-card {
  background: #f5faf9;
}

.task-head,
.board-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.task-badge,
.board-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.task-badge {
  color: #063e46;
  background: #f0d07a;
}

.board-badge {
  color: #0a6e7c;
  background: #dbf1ed;
}

.task-action,
.board-action {
  font-size: 23rpx;
  font-weight: 700;
}

.task-action {
  color: rgba(255, 255, 255, 0.84);
}

.board-action {
  color: #0a6e7c;
}

.board-cart {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0a6e7c, #159888);
}

.cart-plus {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.task-title,
.board-title {
  display: block;
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.task-desc,
.board-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.task-desc {
  color: rgba(255, 255, 255, 0.82);
}

.board-desc {
  color: #5f7275;
}

.task-meta,
.board-meta {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.task-meta {
  color: rgba(255, 255, 255, 0.66);
}

.board-meta {
  color: #7a8a8d;
}
