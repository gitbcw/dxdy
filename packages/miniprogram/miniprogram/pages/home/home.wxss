.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background:
    radial-gradient(circle at 8% 0%, rgba(12, 112, 124, 0.14), transparent 34%),
    linear-gradient(180deg, #f4fbfa 0%, #f8f7f3 42%, #ffffff 100%);
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 38rpx 34rpx;
  border-radius: 40rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #063e46 0%, #0a6e7c 56%, #1f9a8a 100%);
  box-shadow: 0 26rpx 60rpx rgba(6, 62, 70, 0.22);
}

.hero::before,
.hero::after {
  content: "";
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
}

.hero::before {
  top: -120rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
}

.hero::after {
  right: 40rpx;
  bottom: -120rpx;
  width: 200rpx;
  height: 200rpx;
}

.hero-top,
.hero-actions {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-copy {
  flex: 1;
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.74);
}

.title {
  display: block;
  margin-top: 14rpx;
  font-size: 42rpx;
  line-height: 1.26;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.role-pill {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  font-size: 24rpx;
  color: #063e46;
  background: #d9f4ea;
}

.subtitle {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 28rpx;
  width: 88%;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.88);
}

.hero-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 34rpx;
}

.primary-action,
.ghost-action {
  padding: 18rpx 26rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.primary-action {
  color: #063e46;
  background: #f0d07a;
}

.ghost-action {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
}

.identity-card,
.panel {
  margin-top: 22rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(9, 92, 103, 0.09);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(23, 61, 64, 0.08);
}

.identity-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.identity-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}

.identity-copy {
  min-width: 0;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 28rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #0a6e7c, #083d45);
}

.identity-name {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #173236;
}

.identity-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.48;
  color: #6c7b7d;
}

.identity-status {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.identity-status.approved {
  color: #0d5d4d;
  background: #dff7ed;
}

.identity-status.pending {
  color: #7b4f00;
  background: #fff0c2;
}

.identity-status.neutral {
  color: #31505a;
  background: #e8f0f2;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 22rpx;
}

.summary-card {
  padding: 24rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 14rpx 34rpx rgba(23, 61, 64, 0.07);
}

.summary-value {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #0a6e7c;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #173236;
}

.summary-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.45;
  color: #7b8a8c;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #173236;
}

.section-note,
.section-more {
  font-size: 23rpx;
  line-height: 1.4;
  color: #0a6e7c;
}

.task-list,
.board-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-card,
.board-card {
  padding: 24rpx;
  border-radius: 28rpx;
}

.task-card {
  color: #ffffff;
  background: linear-gradient(135deg, #093f47, #0c6f7d 58%, #159888 100%);
}

.board-card {
  background: #f5faf9;
}

.task-head,
.board-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.task-badge,
.board-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.task-badge {
  color: #063e46;
  background: #f0d07a;
}

.board-badge {
  color: #0a6e7c;
  background: #dbf1ed;
}

.task-action,
.board-action {
  font-size: 23rpx;
  font-weight: 700;
}

.task-action {
  color: rgba(255, 255, 255, 0.84);
}

.board-action {
  color: #0a6e7c;
}

.task-title,
.board-title {
  display: block;
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.task-desc,
.board-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.task-desc {
  color: rgba(255, 255, 255, 0.82);
}

.board-desc {
  color: #5f7275;
}

.task-meta,
.board-meta {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.task-meta {
  color: rgba(255, 255, 255, 0.66);
}

.board-meta {
  color: #7a8a8d;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.quick-card {
  padding: 24rpx;
  border-radius: 26rpx;
  background: #f6faf9;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 20rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #0a6e7c, #159888);
}

.quick-title {
  display: block;
  margin-top: 18rpx;
  color: #173236;
  font-size: 28rpx;
  font-weight: 800;
}

.quick-desc {
  display: block;
  margin-top: 8rpx;
  color: #738487;
  font-size: 22rpx;
  line-height: 1.5;
}
