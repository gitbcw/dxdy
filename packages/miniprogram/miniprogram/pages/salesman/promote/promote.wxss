.page {
  min-height: 100vh;
  background: var(--bg-page);
  display: flex;
  flex-direction: column;
  padding-bottom: 48rpx;
}

.page-header {
  background: linear-gradient(160deg, var(--color-primary) 0%, #0D8A9A 100%);
  padding: 32rpx;
  padding-top: calc(32rpx + env(safe-area-inset-top));
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.qrcode-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 32rpx;
}

.qrcode-card {
  width: 100%;
  margin: 0 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
}

.qrcode-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.qrcode-img {
  width: 420rpx;
  height: 420rpx;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
}

.qrcode-hint {
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  background: linear-gradient(160deg, var(--color-primary) 0%, #0D8A9A 100%);
  color: #FFFFFF;
  border: none;
}

.btn::after {
  border: none;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
}
