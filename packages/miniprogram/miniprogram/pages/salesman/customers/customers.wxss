.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(10, 110, 124, 0.12), transparent 34%),
    linear-gradient(180deg, #f4fbfa 0%, #ffffff 100%);
  box-sizing: border-box;
}

.hero,
.section {
  padding: 30rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 16rpx 44rpx rgba(23, 61, 64, 0.08);
}

.hero {
  color: #ffffff;
  background: linear-gradient(135deg, #063e46 0%, #0a6e7c 58%, #159c88 100%);
}

.hero-eyebrow {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.74);
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 900;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
  line-height: 1.65;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.summary-card {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 34rpx rgba(23, 61, 64, 0.07);
}

.summary-value {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #0a6e7c;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #173236;
}

.summary-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.45;
  color: #7b8a8c;
}

.section {
  margin-top: 20rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #173236;
  font-size: 30rpx;
  font-weight: 900;
}

.section-more {
  color: #0a6e7c;
  font-size: 23rpx;
}

.focus-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.focus-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f5faf9;
}

.focus-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.focus-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #0a6e7c;
  font-size: 21rpx;
  font-weight: 800;
  background: #dff4ef;
}

.focus-amount {
  color: #b77700;
  font-size: 28rpx;
  font-weight: 900;
}

.focus-name {
  display: block;
  margin-top: 16rpx;
  color: #173236;
  font-size: 28rpx;
  font-weight: 800;
}

.focus-desc {
  display: block;
  margin-top: 10rpx;
  color: #607174;
  font-size: 23rpx;
  line-height: 1.55;
}

.focus-meta {
  display: block;
  margin-top: 12rpx;
  color: #7a8a8d;
  font-size: 22rpx;
}

.filters {
  margin: 18rpx 0 14rpx;
  white-space: nowrap;
}

.filter-pill {
  display: inline-block;
  margin-right: 14rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  color: #627678;
  font-size: 24rpx;
  background: #edf4f3;
}

.filter-pill.active {
  color: #ffffff;
  font-weight: 800;
  background: #0a6e7c;
}

.customer-list {
  padding-bottom: env(safe-area-inset-bottom);
}

.customer-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 14rpx 36rpx rgba(23, 61, 64, 0.07);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0a6e7c, #159c88);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #173236;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 14rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.type-tag.tag-personal {
  background: rgba(10, 110, 124, 0.12);
  color: #0a6e7c;
}

.type-tag.tag-institution {
  background: rgba(212, 168, 83, 0.15);
  color: #b8923e;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
}

.stat-text {
  font-size: 24rpx;
  color: #6d7f82;
}

.stat-divider {
  width: 1rpx;
  height: 20rpx;
  background: #d9e4e3;
}

.priority-text {
  display: block;
  margin-top: 12rpx;
  color: #607174;
  font-size: 23rpx;
  line-height: 1.5;
}

.exchange-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.exchange-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 14rpx;
  font-size: 20rpx;
  font-weight: 600;
  background: rgba(220, 53, 69, 0.1);
  color: #d14f4f;
}
