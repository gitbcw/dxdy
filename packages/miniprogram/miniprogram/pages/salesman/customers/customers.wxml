<view class="page">
  <view class="hero">
    <text class="hero-eyebrow">业务员客户工作台</text>
    <text class="hero-title">先跟进最值得成交的客户</text>
    <text class="hero-subtitle">把高活跃客户、机构客户和售后关注客户分开看，比单纯列清单更适合真实跟进。</text>
  </view>

  <view class="summary-grid">
    <view wx:for="{{summaryCards}}" wx:key="label" class="summary-card">
      <text class="summary-value">{{item.value}}</text>
      <text class="summary-label">{{item.label}}</text>
      <text class="summary-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">今天优先关注</text>
      <text class="section-more">按成交潜力排序</text>
    </view>
    <view class="focus-list">
      <view wx:for="{{focusCustomers}}" wx:key="id" class="focus-card">
        <view class="focus-top">
          <text class="focus-badge">{{item.priorityTag}}</text>
          <text class="focus-amount">¥{{item.amountText}}</text>
        </view>
        <text class="focus-name">{{item.nickname}}</text>
        <text class="focus-desc">{{item.priorityText}}</text>
        <text class="focus-meta">下单 {{item.orderCount}} 次 · 售后 {{item.exchangeCount}} 次</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-x class="filters">
    <view
      wx:for="{{filters}}"
      wx:key="key"
      class="filter-pill {{activeFilter === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onFilterTap"
    >
      {{item.label}} {{item.count}}
    </view>
  </scroll-view>

  <view class="customer-list">
    <block wx:for="{{visibleCustomers}}" wx:key="id">
      <view class="customer-card">
        <view class="avatar">
          <text class="avatar-text">{{item.avatarText}}</text>
        </view>

        <view class="info">
          <view class="name-row">
            <text class="name">{{item.nickname}}</text>
            <text class="type-tag tag-{{item.type}}">{{item.type === 'personal' ? '个人' : '医院'}}</text>
          </view>

          <view class="stats-row">
            <text class="stat-text">下单 {{item.orderCount}} 次</text>
            <text class="stat-divider"></text>
            <text class="stat-text">累计 ¥{{item.amountText}}</text>
          </view>

          <text class="priority-text">{{item.priorityText}}</text>

          <view class="exchange-row" wx:if="{{item.exchangeCount > 0}}">
            <text class="exchange-tag">售后 {{item.exchangeCount}} 次</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
