<view class="commission-page">
  <!-- 页面顶部：标题 -->
  <view class="page-header">
    <text class="page-title">我的佣金</text>
  </view>

  <!-- 核心数字卡片 -->
  <view class="main-card">
    <view class="main-card-inner">
      <text class="withdrawable-amount">¥{{summary.withdrawable}}</text>
      <text class="withdrawable-label">可提现</text>
    </view>
  </view>

  <!-- 三列统计卡片 -->
  <view class="stat-row">
    <view class="stat-item">
      <text class="stat-value">¥{{summary.total}}</text>
      <text class="stat-label">累计佣金</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">¥{{summary.withdrawn}}</text>
      <text class="stat-label">已提现</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">¥{{summary.pending}}</text>
      <text class="stat-label">待抵扣</text>
    </view>
  </view>

  <!-- 提成明细列表 -->
  <view class="records-section">
    <view class="section-header">
      <text class="section-title">提成明细</text>
    </view>
    <view wx:if="{{records.length === 0}}" class="empty-records">
      <text class="empty-text">暂无提成记录</text>
    </view>
    <view wx:for="{{records}}" wx:key="id" class="record-item">
      <view class="record-left">
        <text class="record-source">{{item.sourceLabel}}</text>
        <text class="record-desc">{{item.description}}</text>
        <text class="record-date">{{item.createdAt}}</text>
      </view>
      <view class="record-right">
        <text class="record-amount {{item.amountClass}}">{{item.amountText}}</text>
      </view>
    </view>
  </view>

  <!-- 底部申请提现按钮 -->
  <view class="btn-wrap">
    <button
      class="btn-withdraw {{canWithdraw ? '' : 'btn-disabled'}}"
      disabled="{{!canWithdraw}}"
      bindtap="onWithdraw"
    >申请提现</button>
    <text class="withdraw-hint" wx:if="{{!canWithdraw}}">可提现金额需满100元</text>
  </view>
</view>
