.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background:
    radial-gradient(circle at 8% 0%, rgba(12, 112, 124, 0.14), transparent 34%),
    linear-gradient(180deg, #f4fbfa 0%, #f8f7f3 42%, #ffffff 100%);
  box-sizing: border-box;
}

/* 商品图片占位 */
.product-image {
  width: 100%;
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8f4f2, #f0f7f6);
}

.image-placeholder {
  font-size: 30rpx;
  color: #879395;
  font-weight: 600;
}

/* 价格栏 */
.price-bar {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  padding: 28rpx 32rpx 0;
}

.price {
  font-size: 48rpx;
  font-weight: 900;
  color: #c0392b;
}

.stock {
  font-size: 24rpx;
  color: #879395;
}

/* 商品名称 */
.product-name {
  display: block;
  padding: 16rpx 32rpx 0;
  font-size: 36rpx;
  font-weight: 800;
  color: #173236;
  line-height: 1.4;
}

.product-spec {
  display: block;
  padding: 12rpx 32rpx 0;
  font-size: 26rpx;
  color: #6c7b7d;
}

/* 详情区块 */
.detail-section {
  margin: 28rpx 24rpx 0;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(9, 92, 103, 0.08);
}

.detail-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #173236;
  margin-bottom: 12rpx;
}

.detail-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: #5f7275;
}

/* 底部留白 */
.bottom-spacer {
  height: 28rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(9, 92, 103, 0.08);
  box-shadow: 0 -8rpx 24rpx rgba(23, 61, 64, 0.06);
}

.btn-cart,
.btn-buy {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
}

.btn-cart {
  color: #0a6e7c;
  background: #e0f3f0;
  margin-right: 16rpx;
}

.btn-buy {
  color: #ffffff;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}
