.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(10, 110, 124, 0.18), transparent 36%),
    linear-gradient(180deg, #f2fbfa 0%, #ffffff 100%);
  box-sizing: border-box;
}

.form {
  width: 100%;
  padding: 40rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 70rpx rgba(23, 61, 64, 0.12);
  box-sizing: border-box;
}

.title {
  display: block;
  color: #113438;
  font-size: 48rpx;
  font-weight: 900;
  text-align: center;
}

.subtitle {
  display: block;
  margin: 16rpx auto 42rpx;
  color: #6d7b7d;
  font-size: 24rpx;
  line-height: 1.6;
  text-align: center;
}

.input {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(10, 110, 124, 0.14);
  border-radius: 18rpx;
  color: #113438;
  font-size: 30rpx;
  background: #f7fbfa;
}

.submit-btn {
  margin-top: 12rpx;
  padding: 24rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}

.switch {
  display: block;
  margin-top: 28rpx;
  color: #0a6e7c;
  font-size: 26rpx;
  text-align: center;
}

.demo-box {
  margin-top: 40rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #f4f8f7;
}

.demo-title {
  display: block;
  margin-bottom: 18rpx;
  color: #113438;
  font-size: 28rpx;
  font-weight: 800;
}

.demo-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.demo-item {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
}

.demo-label {
  display: block;
  color: #113438;
  font-size: 24rpx;
  font-weight: 800;
}

.demo-phone {
  display: block;
  margin-top: 8rpx;
  color: #879395;
  font-size: 21rpx;
}
