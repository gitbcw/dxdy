<view class="page">
  <view wx:if="{{!userInfo}}" class="login-prompt">
    <view class="avatar-empty">DX</view>
    <text class="login-title">登录工作账号</text>
    <text class="login-desc">进入采购、订单、业务员和制单员对应工作台。</text>
    <view class="login-btn" bindtap="onLoginTap">立即登录</view>
  </view>

  <view wx:else>
    <view class="profile-card">
      <view class="profile-top">
        <view class="avatar">{{avatarText}}</view>
        <view class="info">
          <text class="name">{{userInfo.nickname}}</text>
          <text class="type">{{userRoleLabel}}</text>
        </view>
        <view class="switch-pill" bindtap="onSwitchRole">工作身份</view>
      </view>
      <text class="role-desc">{{roleDesc}}</text>
      <text class="headline">{{pageHeadline}}</text>
      <text class="subhead">{{pageSubhead}}</text>
    </view>

    <view class="stats">
      <view wx:for="{{stats}}" wx:key="label" class="stat">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
        <text class="stat-desc">{{item.desc}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">{{focusTitle}}</text>
        <text class="section-more" bindtap="onSwitchRole">切换身份 ></text>
      </view>
      <view class="focus-list">
        <view
          wx:for="{{focusItems}}"
          wx:key="id"
          class="focus-card"
          data-id="{{item.id}}"
          bindtap="onFocusItemTap"
        >
          <view class="focus-top">
            <text class="focus-badge">{{item.badge}}</text>
            <text class="focus-arrow">›</text>
          </view>
          <text class="focus-title">{{item.title}}</text>
          <text class="focus-desc">{{item.desc}}</text>
          <text class="focus-meta">{{item.meta}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">常用入口</text>
        <text class="section-more" bindtap="onSwitchRole">换个视角 ></text>
      </view>
      <view class="menu">
        <view
          wx:for="{{menuItems}}"
          wx:key="id"
          class="menu-item {{item.accent ? 'accent' : ''}}"
          data-id="{{item.id}}"
          bindtap="onMenuItemTap"
        >
          <view>
            <text class="menu-title">{{item.title}}</text>
            <text class="menu-desc">{{item.desc}}</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <view class="logout" bindtap="onLogout">退出当前账号</view>
  </view>
</view>
