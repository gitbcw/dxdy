<view class="page">
  <view wx:if="{{!userInfo}}" class="login-prompt">
    <view class="avatar-empty">DX</view>
    <text class="login-title">登录工作账号</text>
    <text class="login-desc">登录后可查看订单和采购</text>
    <view class="login-btn" bindtap="onLoginTap">立即登录</view>
  </view>

  <view wx:else>
    <view class="profile-card {{compactProfile ? 'compact' : ''}}">
      <view class="profile-top">
        <view class="avatar">{{avatarText}}</view>
        <view class="info">
          <text class="name">{{userInfo.nickname}}</text>
          <text class="type">{{userRoleLabel}}</text>
        </view>
      </view>
      <view class="profile-stats" wx:if="{{stats.length > 0}}">
        <view wx:for="{{stats}}" wx:key="label" class="profile-stat">
          <text class="profile-stat-label">{{item.label}}</text>
          <text class="profile-stat-value">{{item.value}}</text>
        </view>
      </view>
      <text wx:if="{{statNote}}" class="profile-note">{{statNote}}</text>
    </view>

    <view class="order-bar" wx:if="{{showOrderBar}}">
      <view class="order-bar-item" bindtap="onOrdersTap">
        <view class="order-icon-wrap">
          <view class="order-icon">全</view>
        </view>
        <text class="order-label">全部</text>
      </view>
      <view class="order-bar-item" bindtap="onPendingPaymentTap">
        <view class="order-icon-wrap">
          <view class="order-icon">付</view>
          <view class="order-badge" wx:if="{{orderCounts.pendingPayment > 0}}">{{orderCounts.pendingPayment}}</view>
        </view>
        <text class="order-label">待付款</text>
      </view>
      <view class="order-bar-item" bindtap="onPendingReceiptTap">
        <view class="order-icon-wrap">
          <view class="order-icon">收</view>
          <view class="order-badge" wx:if="{{orderCounts.pendingReceipt > 0}}">{{orderCounts.pendingReceipt}}</view>
        </view>
        <text class="order-label">待收货</text>
      </view>
      <view class="order-bar-item" bindtap="onCompletedTap">
        <view class="order-icon-wrap">
          <view class="order-icon">完</view>
        </view>
        <text class="order-label">已完结</text>
      </view>
    </view>

    <view class="section" wx:if="{{focusItems.length > 0}}">
      <view class="section-head">
        <text class="section-title">{{focusTitle}}</text>
      </view>
      <view class="focus-list">
        <view
          wx:for="{{focusItems}}"
          wx:key="id"
          class="focus-card"
          data-id="{{item.id}}"
          bindtap="onFocusItemTap"
        >
          <view class="focus-top">
            <text class="focus-badge">{{item.badge}}</text>
            <text class="focus-arrow">›</text>
          </view>
          <text class="focus-title">{{item.title}}</text>
          <text class="focus-desc">{{item.desc}}</text>
          <text class="focus-meta">{{item.meta}}</text>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{menuItems.length > 0}}">
      <view class="menu">
        <view
          wx:for="{{menuItems}}"
          wx:key="id"
          class="menu-item {{item.accent ? 'accent' : ''}}"
          data-id="{{item.id}}"
          bindtap="onMenuItemTap"
        >
          <view>
            <text class="menu-title">{{item.title}}</text>
            <text class="menu-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <view class="bottom-actions">
      <view class="action-btn switch-role" bindtap="onSwitchRole">切换身份</view>
      <view class="action-btn logout" bindtap="onLogout">退出当前账号</view>
    </view>
  </view>
</view>
