.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom) + 136rpx);
  background:
    radial-gradient(circle at 0% 0%, rgba(10, 110, 124, 0.14), transparent 34%),
    linear-gradient(180deg, #f4fbfa 0%, #ffffff 100%);
  box-sizing: border-box;
}

/* 未登录 */
.login-prompt {
  margin-top: 120rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 44rpx rgba(23, 61, 64, 0.08);
}

.avatar-empty {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  margin: 0 auto;
  border-radius: 32rpx;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}

.login-title {
  display: block;
  margin-top: 26rpx;
  color: #173236;
  font-size: 38rpx;
  font-weight: 900;
}

.login-desc {
  display: block;
  margin-top: 14rpx;
  color: #78888a;
  font-size: 24rpx;
  line-height: 1.6;
}

.login-btn {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}

/* 个人信息卡片 */
.profile-card {
  padding: 32rpx;
  border-radius: 32rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #063e46 0%, #0a6e7c 58%, #159c88 100%);
}

.profile-card.compact {
  padding: 28rpx;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  color: #063e46;
  font-size: 38rpx;
  font-weight: 900;
  background: #dff7ed;
}

.info {
  flex: 1;
}

.name {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
}

.type {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 23rpx;
}

/* 卡片内嵌统计（两端对齐） */
.profile-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.profile-card.compact .profile-stats {
  gap: 20rpx;
  justify-content: flex-start;
}

.profile-stat {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  min-width: 0;
}

.profile-card.compact .profile-stat {
  flex: 1;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.profile-stat-value {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.profile-stat-label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
}

.profile-card.compact .profile-stat-label {
  font-size: 22rpx;
}

.profile-note {
  display: block;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
}

/* 订单状态入口（客户专属） */
.order-bar {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 12rpx;
  margin-top: 20rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 38rpx rgba(23, 61, 64, 0.07);
}

.order-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.order-icon-wrap {
  position: relative;
}

.order-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #f0f8f7;
  color: #0a6e7c;
  font-size: 34rpx;
  font-weight: 900;
}

.order-badge {
  position: absolute;
  top: -10rpx;
  right: -18rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #d14f4f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  text-align: center;
}

.order-label {
  color: #173236;
  font-size: 24rpx;
  font-weight: 700;
}

/* 焦点区域（业务员/制单员） */
.section {
  margin-top: 20rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 44rpx rgba(23, 61, 64, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  color: #173236;
  font-size: 30rpx;
  font-weight: 900;
}

.focus-list,
.menu {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.focus-card,
.menu-item {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
}

.focus-card {
  background: #f5faf9;
}

.focus-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.focus-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #0a6e7c;
  font-size: 21rpx;
  font-weight: 800;
  background: #dff4ef;
}

.focus-arrow,
.arrow {
  color: #91a0a3;
  font-size: 34rpx;
}

.focus-title {
  display: block;
  margin-top: 14rpx;
  color: #173236;
  font-size: 28rpx;
  font-weight: 800;
}

.focus-desc {
  display: block;
  margin-top: 8rpx;
  color: #607174;
  font-size: 23rpx;
  line-height: 1.55;
}

.focus-meta {
  display: block;
  margin-top: 10rpx;
  color: #7a8a8d;
  font-size: 22rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: #f6faf9;
}

.menu-item.accent {
  color: #ffffff;
  background: linear-gradient(135deg, #0a6e7c, #139783);
}

.menu-title {
  display: block;
  color: #173236;
  font-size: 28rpx;
  font-weight: 800;
}

.menu-desc {
  display: block;
  margin-top: 8rpx;
  color: #7c8d8f;
  font-size: 22rpx;
  line-height: 1.5;
}

.menu-item.accent .menu-title,
.menu-item.accent .menu-desc,
.menu-item.accent .arrow {
  color: #ffffff;
}

/* 底部操作 */
.bottom-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 48rpx;
}

.action-btn {
  padding: 24rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
}

.action-btn.switch-role {
  color: #0a6e7c;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 38rpx rgba(23, 61, 64, 0.07);
}

.action-btn.logout {
  color: #ffffff;
  background: #d14f4f;
}
