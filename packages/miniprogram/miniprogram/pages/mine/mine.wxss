.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(10, 110, 124, 0.14), transparent 34%),
    linear-gradient(180deg, #f3fbfa 0%, #ffffff 100%);
  box-sizing: border-box;
}

.login-prompt,
.profile-card,
.section,
.demo-note {
  padding: 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 44rpx rgba(23, 61, 64, 0.08);
}

.login-prompt {
  margin-top: 120rpx;
  text-align: center;
}

.avatar-empty {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  margin: 0 auto;
  border-radius: 32rpx;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}

.login-title {
  display: block;
  margin-top: 26rpx;
  color: #173236;
  font-size: 38rpx;
  font-weight: 900;
}

.login-desc {
  display: block;
  margin-top: 14rpx;
  color: #78888a;
  font-size: 24rpx;
  line-height: 1.6;
}

.login-btn,
.logout {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
}

.login-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}

.profile-card {
  color: #ffffff;
  background: linear-gradient(135deg, #063e46, #0a6e7c 58%, #159c88 100%);
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  color: #063e46;
  font-size: 38rpx;
  font-weight: 900;
  background: #dff7ed;
}

.info {
  flex: 1;
}

.name {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
}

.type {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
}

.switch-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #063e46;
  font-size: 22rpx;
  font-weight: 800;
  background: #dff7ed;
}

.role-desc {
  display: block;
  margin-top: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 1.6;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat {
  padding: 24rpx 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 38rpx rgba(23, 61, 64, 0.07);
}

.stat-value {
  display: block;
  color: #0a6e7c;
  font-size: 32rpx;
  font-weight: 900;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #173236;
  font-size: 24rpx;
  font-weight: 800;
}

.stat-desc {
  display: block;
  margin-top: 8rpx;
  color: #7b8b8d;
  font-size: 20rpx;
  line-height: 1.45;
}

.section {
  margin-top: 20rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  color: #173236;
  font-size: 30rpx;
  font-weight: 900;
}

.section-more {
  color: #0a6e7c;
  font-size: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 14rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f6faf9;
}

.menu-item.accent {
  color: #ffffff;
  background: linear-gradient(135deg, #0a6e7c, #139783);
}

.menu-title {
  display: block;
  color: #173236;
  font-size: 28rpx;
  font-weight: 800;
}

.menu-desc {
  display: block;
  margin-top: 8rpx;
  color: #7c8d8f;
  font-size: 22rpx;
  line-height: 1.5;
}

.menu-item.accent .menu-title,
.menu-item.accent .menu-desc,
.menu-item.accent .arrow {
  color: #ffffff;
}

.arrow {
  color: #91a0a3;
  font-size: 34rpx;
}

.demo-note {
  margin-top: 20rpx;
  background: #fff7de;
}

.note-title {
  display: block;
  color: #6f4e08;
  font-size: 28rpx;
  font-weight: 900;
}

.note-text {
  display: block;
  margin-top: 12rpx;
  color: #876828;
  font-size: 23rpx;
  line-height: 1.6;
}

.logout {
  color: #ffffff;
  background: #d14f4f;
}
