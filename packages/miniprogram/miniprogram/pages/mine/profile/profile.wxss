.page {
  min-height: 100vh;
  background: var(--bg-page);
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 36rpx;
  background: linear-gradient(160deg, var(--color-primary), var(--color-primary-light));
}

.avatar-large {
  width: 128rpx;
  height: 128rpx;
  line-height: 128rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 52rpx;
  font-weight: 900;
  text-align: center;
}

.profile-name {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
}

.field-list {
  margin: 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.field-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-bottom: 1rpx solid var(--divider-color);
}

.field-item:last-child {
  border-bottom: none;
}

.field-item.readonly {
  opacity: 0.7;
}

.field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex-shrink: 0;
}

.field-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar-small {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

.field-value {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: right;
}

.field-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
}
