<view class="page">
  <view class="fav-list">
    <view
      wx:for="{{favorites}}"
      wx:key="id"
      class="fav-card"
      data-id="{{item.id}}"
      bindtap="onItemTap"
    >
      <view class="fav-image">
        <view class="image-placeholder">检</view>
      </view>
      <view class="fav-info">
        <text class="fav-name">{{item.name}}</text>
        <text class="fav-specs">{{item.specs}}</text>
        <view class="fav-bottom">
          <view class="fav-price-row">
            <text class="fav-price">¥{{item.price}}</text>
            <text class="fav-original">¥{{item.originalPrice}}</text>
          </view>
          <text class="fav-sales">已售 {{item.salesCount}}</text>
        </view>
      </view>
      <view class="fav-actions" catchtap="">
        <view class="fav-cart" data-id="{{item.id}}" catchtap="onAddToCart">加购</view>
        <view class="fav-remove" data-id="{{item.id}}" catchtap="onRemoveFavorite">取消</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{favorites.length === 0}}">
    <text class="empty-icon">♡</text>
    <text class="empty-text">暂无收藏商品</text>
    <text class="empty-hint">浏览商品时点击收藏即可添加</text>
  </view>
</view>
