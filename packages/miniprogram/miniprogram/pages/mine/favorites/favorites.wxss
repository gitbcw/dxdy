.page {
  min-height: 100vh;
  padding: 24rpx;
  background: var(--bg-page);
  box-sizing: border-box;
}

.fav-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.fav-card {
  display: flex;
  gap: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-color);
}

.fav-image {
  flex-shrink: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8f4f5, #d4ede9);
  color: var(--color-primary);
  font-size: 44rpx;
  font-weight: 900;
}

.fav-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.fav-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.fav-specs {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.fav-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.fav-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.fav-price {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--color-accent);
}

.fav-original {
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-decoration: line-through;
}

.fav-sales {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.fav-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.fav-cart,
.fav-remove {
  padding: 10rpx 20rpx;
  border-radius: var(--radius-md);
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
}

.fav-cart {
  background: var(--color-primary);
  color: #fff;
}

.fav-remove {
  background: var(--bg-section);
  color: var(--text-tertiary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}
