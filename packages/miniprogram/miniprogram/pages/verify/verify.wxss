.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(10, 110, 124, 0.18), transparent 36%),
    linear-gradient(180deg, #f2fbfa 0%, #ffffff 100%);
  box-sizing: border-box;
}

/* 状态卡片（审核中 / 已通过） */
.status-card {
  margin-top: 80rpx;
  padding: 48rpx 36rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 70rpx rgba(23, 61, 64, 0.12);
  text-align: center;
}

.status-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  font-size: 40rpx;
  font-weight: 900;
  color: #ffffff;
}

.status-icon.pending {
  background: linear-gradient(135deg, #c88a00, #e6a817);
}

.status-icon.approved {
  background: linear-gradient(135deg, #0a6e7c, #159888);
}

.status-title {
  display: block;
  margin-top: 28rpx;
  font-size: 38rpx;
  font-weight: 900;
  color: #113438;
}

.status-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6d7b7d;
}

.status-info {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #f4f8f7;
}

.info-label {
  font-size: 26rpx;
  color: #6d7b7d;
}

.info-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #113438;
}

/* 认证表单 */
.form {
  padding: 36rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 70rpx rgba(23, 61, 64, 0.12);
}

.form-title {
  display: block;
  font-size: 42rpx;
  font-weight: 900;
  color: #113438;
}

.form-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6d7b7d;
}

.reject-notice {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #fff5f5;
  border-left: 6rpx solid #e54d42;
}

.reject-label {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #e54d42;
}

.reject-reason {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #7b4f4f;
}

.form-section {
  margin-top: 30rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #113438;
}

.form-input {
  padding: 24rpx;
  border: 1rpx solid rgba(10, 110, 124, 0.14);
  border-radius: 18rpx;
  color: #113438;
  font-size: 30rpx;
  background: #f7fbfa;
}

.upload-area {
  width: 100%;
  min-height: 280rpx;
  border: 2rpx dashed rgba(10, 110, 124, 0.24);
  border-radius: 18rpx;
  background: #f7fbfa;
  overflow: hidden;
}

.license-preview {
  width: 100%;
  height: 280rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 280rpx;
}

.upload-icon {
  font-size: 64rpx;
  color: #0a6e7c;
  font-weight: 300;
}

.upload-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #879395;
}

.submit-btn {
  margin-top: 40rpx;
  padding: 24rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
  background: linear-gradient(135deg, #063e46, #0a6e7c);
}

.back-btn {
  margin-top: 36rpx;
  padding: 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(10, 110, 124, 0.2);
  color: #0a6e7c;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}
